{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions: core + sql + http. Plugin-scraper fetches use a permissive HTTPS/HTTP scope; tighten in v0.2 once a plugin allowlist exists.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "deep-link:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" },
        { "url": "https://**:*/**" },
        { "url": "http://**:*/**" }
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [{ "url": "https://github.com/**" }]
    }
  ]
}
