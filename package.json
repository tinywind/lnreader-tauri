{
  "name": "norea",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "android:apk:release": "tauri android build --apk --split-per-abi --target aarch64 --target x86_64",
    "android:apk:aarch64": "tauri android build --apk --split-per-abi --target aarch64",
    "android:apk:x86_64": "tauri android build --apk --split-per-abi --target x86_64",
    "android:apk:wsa": "pnpm android:apk:x86_64",
    "android:apk:device": "pnpm android:apk:aarch64",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@mantine/core": "^7.14.3",
    "@mantine/hooks": "^7.14.3",
    "@mantine/notifications": "^9.1.1",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-router": "^1.95.0",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-deep-link": "^2.4.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-http": "^2.4.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-sql": "^2.2.0",
    "cheerio": "^1.0.0",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.36.4",
    "htmlparser2": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.30.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.27.0"
}
