{
  "name": "norea",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare": "node scripts/install-git-hooks.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "node scripts/tauri-channel.mjs",
    "android:apk:release": "tauri android build --apk --split-per-abi --target aarch64 --target x86_64",
    "windows:bundle:release": "pnpm windows:bundle:x86_64 && pnpm windows:bundle:arm64",
    "windows:bundle:x86_64": "pnpm tauri build --target x86_64-pc-windows-msvc --bundles nsis,msi",
    "windows:bundle:arm64": "pnpm tauri build --target aarch64-pc-windows-msvc --bundles nsis,msi",
    "linux:bundle:release": "pnpm linux:bundle:x86_64 && pnpm linux:bundle:arm64",
    "linux:bundle:x86_64": "pnpm tauri build --target x86_64-unknown-linux-gnu --bundles appimage,deb,rpm",
    "linux:bundle:arm64": "pnpm tauri build --target aarch64-unknown-linux-gnu --bundles appimage,deb,rpm",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@mantine/notifications": "^9.1.1",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "cheerio": "^1.2.0",
    "css-tree": "^3.2.1",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.2",
    "htmlparser2": "^12.0.0",
    "marked": "^18.0.3",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "~6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.27.0"
}
